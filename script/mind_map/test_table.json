  "cards": [

    {
      "id": 1,
      "title": "Core Annotations",
      "color": "orange",
      "content": [
        {
          "type": "table",
          "headers": ["Annotation", "Scope"],
          "key_col": true,
          "rows": [
            ["@SpringBootApplication", "Main class, enables autoconfiguration"],
            ["@RestController",        "HTTP controller, returns JSON/text"],
            ["@Service",               "Business logic layer"],
            ["@Repository",            "Data access layer + exception translation"]
          ]
        },
        {
          "type": "note",
          "content": "@Component is the base of @Service, @Repository, @Controller"
        }
      ]
    },

    {
      "id": 2,
      "title": "Dependency Injection",
      "color": "green",
      "content": [
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "@Autowired on constructor (preferred)",
            "@Qualifier to pick a specific bean",
            "@Primary marks the default bean",
            "Lombok @RequiredArgsConstructor",
            "@Value(\"${prop}\") injects properties"
          ]
        }
      ]
    },

    {
      "id": 3,
      "title": "REST Mapping",
      "color": "blue",
      "content": [
        {
          "type": "table",
          "headers": ["Annotation", "HTTP", "Typical use"],
          "rows": [
            ["@GetMapping",    "GET",    "Read resource"],
            ["@PostMapping",   "POST",   "Create resource"],
            ["@PutMapping",    "PUT",    "Full update"],
            ["@PatchMapping",  "PATCH",  "Partial update"],
            ["@DeleteMapping", "DELETE", "Remove resource"]
          ]
        }
      ]
    },

    {
      "id": 4,
      "title": "application.properties",
      "color": "amber",
      "content": [
        {
          "type": "kv_list",
          "items": [
            {"key": "server.port",          "value": "8080 (default)"},
            {"key": "spring.profiles.active","value": "dev | prod | test"},
            {"key": "spring.datasource.url", "value": "jdbc:postgresql://..."},
            {"key": "logging.level.root",    "value": "INFO | DEBUG | WARN"},
            {"key": "spring.jpa.ddl-auto",   "value": "none | update | create"}
          ]
        }
      ]
    },

    {
      "id": 5,
      "title": "Request Parameters",
      "color": "navy",
      "content": [
        {
          "type": "shot_grid",
          "items": [
            {
              "label": "@PathVariable",
              "style": "zero",
              "text": "/users/{id} → Long id"
            },
            {
              "label": "@RequestParam",
              "style": "one",
              "text": "?page=1&size=20 → int page"
            },
            {
              "label": "@RequestBody",
              "style": "few",
              "text": "JSON body → @Valid UserDto dto"
            }
          ]
        },
        {
          "type": "note",
          "content": "Use @Valid + BindingResult for input validation"
        }
      ]
    },

    {
      "id": 6,
      "title": "JPA / Hibernate",
      "color": "darkgreen",
      "content": [
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "@Entity + @Table(name=\"...\")",
            "@Id + @GeneratedValue",
            "@Column(nullable=false, length=255)",
            "@OneToMany / @ManyToOne + @JoinColumn",
            "@Transactional on service methods",
            "Spring Data: extends JpaRepository<E,ID>"
          ]
        }
      ]
    },

    {
      "id": 7,
      "title": "Query Methods",
      "color": "teal",
      "content": [
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "findByEmail(String email)",
            "findAllByActiveTrue()",
            "existsByUsername(String u)",
            "countByRole(Role role)",
            "@Query(\"SELECT u FROM User u WHERE...\")",
            "Pageable + Page<T> for pagination"
          ]
        }
      ]
    },

    {
      "id": 8,
      "title": "Profiles & Config",
      "color": "purple",
      "content": [
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "application-dev.properties",
            "application-prod.properties",
            "@Profile(\"dev\") on @Bean",
            "@ConfigurationProperties(prefix=\"app\")",
            "Environment variable override: SERVER_PORT=9090",
            "spring.config.import=optional:file:.env[.properties]"
          ]
        }
      ]
    },

    {
      "id": 9,
      "title": "Spring Security Basics",
      "color": "red",
      "content": [
        {
          "type": "section_label",
          "content": "Dependencies"
        },
        {
          "type": "text_block",
          "html": true,
          "content": "<span class=\"u-code\">spring-boot-starter-security</span> + <span class=\"u-code\">spring-security-test</span>"
        },
        {
          "type": "divider"
        },
        {
          "type": "section_label",
          "content": "SecurityFilterChain"
        },
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "csrf().disable() for stateless REST",
            "sessionManagement → STATELESS",
            "authorizeHttpRequests: permit /auth/**, secure rest",
            "addFilterBefore(jwtFilter, UsernamePasswordAuthFilter)",
            "UserDetailsService + PasswordEncoder bean"
          ]
        },
        {
          "type": "note",
          "content": "Use BCryptPasswordEncoder strength=12 for production"
        }
      ]
    },

    {
      "id": 10,
      "title": "Exception Handling",
      "color": "amber",
      "content": [
        {
          "type": "section_label",
          "content": "@ControllerAdvice"
        },
        {
          "type": "list",
          "style": "arrow",
          "items": [
            "@ExceptionHandler(ResourceNotFoundException.class)",
            "@ExceptionHandler(MethodArgumentNotValidException.class)",
            "Return ResponseEntity<ErrorDto>",
            "Use ProblemDetail (Spring 6+) for RFC 7807"
          ]
        },
        {
          "type": "divider"
        },
        {
          "type": "table",
          "headers": ["HTTP", "Exception type"],
          "rows": [
            ["400", "MethodArgumentNotValidException"],
            ["401", "AuthenticationException"],
            ["403", "AccessDeniedException"],
            ["404", "NoSuchElementException"],
            ["409", "DataIntegrityViolationException"]
          ]
        }
      ]
    },

    {
      "id": 11,
      "title": "Useful Starter Dependencies",
      "color": "blue",
      "content": [
        {
          "type": "table",
          "rows": [
            ["spring-boot-starter-web",        "REST controllers + Tomcat"],
            ["spring-boot-starter-data-jpa",   "JPA + Hibernate + HikariCP"],
            ["spring-boot-starter-validation",  "Bean Validation (JSR-380)"],
            ["spring-boot-starter-security",    "Authentication + filters"],
            ["spring-boot-starter-test",        "JUnit 5 + Mockito + MockMvc"],
            ["spring-boot-starter-actuator",    "Health, metrics endpoints"],
            ["spring-boot-starter-thymeleaf",   "Server-side HTML rendering"],
            ["lombok",                          "Boilerplate reduction"]
          ]
        }
      ]
    },

    {
      "id": 12,
      "title": "Testing Strategy",
      "color": "green",
      "content": [
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "@SpringBootTest → full integration test",
            "@WebMvcTest(Controller.class) → slice test",
            "@DataJpaTest → repository slice + H2",
            "@MockBean to mock Spring beans in context",
            "MockMvc.perform(get(\"/api/...\")).andExpect(status().isOk())",
            "Testcontainers for real DB in integration tests",
            "@Sql to load fixtures before test",
            "@Transactional on test → auto-rollback"
          ]
        }
      ]
    },

    {
      "id": 13,
      "title": "Actuator Endpoints",
      "color": "teal",
      "content": [
        {
          "type": "table",
          "headers": ["Endpoint", "Shows"],
          "key_col": true,
          "rows": [
            ["/actuator/health",   "App + DB + disk status"],
            ["/actuator/info",     "Build + git metadata"],
            ["/actuator/metrics",  "JVM, HTTP, custom meters"],
            ["/actuator/env",      "All properties (sanitized)"],
            ["/actuator/loggers",  "Change log level at runtime"],
            ["/actuator/mappings", "All @RequestMapping routes"],
            ["/actuator/beans",    "All beans in context"]
          ]
        }
      ]
    },

    {
      "id": 14,
      "title": "Common Pitfalls",
      "color": "red",
      "content": [
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "Circular dependency → use @Lazy or refactor",
            "LazyInitializationException → check @Transactional scope",
            "N+1 query → use JOIN FETCH or @EntityGraph",
            "Password in plain text → always BCrypt",
            "Exposing @Entity directly → use DTO + MapStruct",
            "Missing index on FK columns → add @Index",
            "application.properties in VCS → use env vars",
            "@Transactional on private method is ignored"
          ]
        }
      ]
    },

    {
      "id": 15,
      "title": "Production Checklist",
      "color": "orange",
      "force_layout": "full",
      "content": [
        {
          "type": "check_grid",
          "items": [
            "spring.jpa.ddl-auto=none (use Flyway/Liquibase)",
            "Externalize all secrets via env variables",
            "Enable HTTPS / TLS termination at proxy",
            "Configure connection pool (HikariCP max-pool-size)",
            "Set management.endpoints.web.exposure.include",
            "Add /actuator/health to load balancer probe",
            "Enable structured logging (Logback JSON encoder)",
            "Set JVM heap flags: -Xms -Xmx",
            "Containerise with multi-stage Dockerfile",
            "Add Prometheus metrics + Grafana dashboard",
            "Configure graceful shutdown (SIGTERM → 30s drain)",
            "Smoke-test /actuator/health after each deploy"
          ]
        }
      ]
    }

  ]
}